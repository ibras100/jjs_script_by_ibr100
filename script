T5:CreateToggle({
    Name         = "Auto Collect Items",
    CurrentValue = false,
    Flag         = "AutoCollect",
    Callback     = function(v)
        S.AutoCollect = v
        if v then startAutoCollect() end
    end,
})

T5:CreateButton({
    Name     = "Lister items proches",
    Callback = function()
        local found = {}
        local mr    = getRoot()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and isCollectible(obj.Name) then
                local d = mr and (mr.Position - obj.Position).Magnitude or 0
                table.insert(found, obj.Name .. "(" .. math.floor(d) .. "st)")
                if #found >= 8 then break end
            end
        end
        if #found > 0 then
            notify("Items", table.concat(found, " | "), 5)
        else
            notify("Items", "Aucun item detecte.", 3)
        end
    end,
})

