--  ESP
-- ══════════════════════════════════════════════════════════════
local ESPData = {}

local function clearESP()
    for _, objs in pairs(ESPData) do
        for _, o in ipairs(objs) do
            if o and o.Parent then
                pcall(function() o:Destroy() end)
            end
        end
    end
    ESPData = {}
end

local function makeESP(p)
    if ESPData[p.Name] then return end
    if not p.Character then return end
    local pRoot = p.Character:FindFirstChild("HumanoidRootPart")
    local pHum  = p.Character:FindFirstChildOfClass("Humanoid")
    if not pRoot or not pHum then return end

    local objs = {}

    -- Highlight
    local hl            = Instance.new("Highlight")
    hl.FillColor        = S.ESPFill
    hl.OutlineColor     = S.ESPOutline
    hl.FillTransparency    = 0.45
    hl.OutlineTransparency = 0
    hl.Adornee          = p.Character
    hl.Parent           = p.Character
    table.insert(objs, hl)

    -- Billboard
    local bb        = Instance.new("BillboardGui")
    bb.Size         = UDim2.new(0, 160, 0, 58)
    bb.StudsOffset  = Vector3.new(0, 4.5, 0)
    bb.AlwaysOnTop  = true
    bb.Adornee      = pRoot
    bb.Parent       = pRoot

    local bg            = Instance.new("Frame", bb)
    bg.Size             = UDim2.fromScale(1, 1)
    bg.BackgroundColor3 = Color3.fromRGB(8, 8, 14)
    bg.BackgroundTransparency = 0.18
    local bgCorner      = Instance.new("UICorner", bg)
    bgCorner.CornerRadius = UDim.new(0, 8)
    local bgStroke      = Instance.new("UIStroke", bg)
    bgStroke.Color      = S.ESPFill

    local nameL         = Instance.new("TextLabel", bg)
    nameL.Size          = UDim2.new(1, 0, 0.38, 0)
    nameL.BackgroundTransparency = 1
    nameL.TextColor3    = Color3.fromRGB(255, 255, 255)
    nameL.TextScaled    = true
    nameL.Font          = Enum.Font.GothamBold
    nameL.Text          = "⚔ " .. p.Name

    local hpBg          = Instance.new("Frame", bg)
    hpBg.Size           = UDim2.new(0.9, 0, 0.13, 0)
    hpBg.Position       = UDim2.new(0.05, 0, 0.44, 0)
    hpBg.BackgroundColor3 = Color3.fromRGB(60, 10, 10)
    local hpBgC         = Instance.new("UICorner", hpBg)
    hpBgC.CornerRadius  = UDim.new(1, 0)

    local hpFill        = Instance.new("Frame", hpBg)
    hpFill.Size         = UDim2.fromScale(
        math.clamp(pHum.Health / math.max(pHum.MaxHealth, 1), 0, 1), 1
    )
    hpFill.BackgroundColor3 = Color3.fromRGB(50, 220, 80)
    local hpFillC       = Instance.new("UICorner", hpFill)
    hpFillC.CornerRadius = UDim.new(1, 0)

    local infoL         = Instance.new("TextLabel", bg)
    infoL.Size          = UDim2.new(1, 0, 0.3, 0)
    infoL.Position      = UDim2.fromScale(0, 0.68)
    infoL.BackgroundTransparency = 1
    infoL.TextColor3    = Color3.fromRGB(200, 200, 200)
    infoL.TextScaled    = true
    infoL.Font          = Enum.Font.Gotham
    infoL.Text          = "❤ -- / --  📍 --"

    ESPData[p.Name] = objs
    table.insert(objs, bb)

    task.spawn(function()
        while S.ESP and p and p.Character and ESPData[p.Name] do
            local h2  = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
            local r2  = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            local myR = getRoot()
            if h2 and r2 then
                local ratio = math.clamp(h2.Health / math.max(h2.MaxHealth, 1), 0, 1)
                hpFill.Size = UDim2.fromScale(ratio, 1)
                if ratio > 0.6 then
                    hpFill.BackgroundColor3 = Color3.fromRGB(50, 220, 80)
                elseif ratio > 0.3 then
                    hpFill.BackgroundColor3 = Color3.fromRGB(230, 170, 20)
                else
                    hpFill.BackgroundColor3 = Color3.fromRGB(220, 40, 40)
                end
                local d = myR and math.floor((myR.Position - r2.Position).Magnitude) or 0
                infoL.Text = string.format("❤ %d/%d  📍 %d", math.floor(h2.Health), math.floor(h2.MaxHealth), d)
                hl.FillColor    = S.ESPFill
                hl.OutlineColor = S.ESPOutline
            end
            task.wait(0.15)
        end
    end)
end

local function refreshESP()
    for name, _ in pairs(ESPData) do
        if not Players:FindFirstChild(name) then
            ESPData[name] = nil
        end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then
            local pR  = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            local myR = getRoot()
            if pR and myR then
                local d = (myR.Position - pR.Position).Magnitude
                if d <= S.ESPDist and not ESPData[p.Name] then
                    makeESP(p)
                end
            end
        end
    end
end

