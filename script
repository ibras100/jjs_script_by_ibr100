-- ══════════════════════════════════════════════════════════════
--  DASH-TO  — MoveTo method
--  Boosts WalkSpeed then calls Humanoid:MoveTo().
--  Goes around walls naturally, zero extra physics objects.
-- ══════════════════════════════════════════════════════════════
local function dashTo(targetPos, speed, timeout)
    speed   = speed   or 280
    timeout = timeout or 3
    local hum = getHum()
    if not hum then return end
    hum.WalkSpeed = speed
    hum:MoveTo(targetPos)
    local arrived = false
    local conn = hum.MoveToFinished:Connect(function() arrived = true end)
    local elapsed = 0
    while not arrived and elapsed < timeout do elapsed += task.wait() end
    conn:Disconnect()
    hum.WalkSpeed = S.WalkSpeed
end

-- ══════════════════════════════════════════════════════════════
--  TARGET SYSTEM — Players + Dummies/NPCs
-- ══════════════════════════════════════════════════════════════
local function getAllTargets(maxDist)
    maxDist = maxDist or math.huge
    local myRoot = getRoot()
    if not myRoot then return {} end
    local seen, list = {}, {}

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if r and h and h.Health > 0 and not seen[r] then
                local d = (myRoot.Position - r.Position).Magnitude
                if d <= maxDist then
                    seen[r] = true
                    table.insert(list, {root=r, hum=h, name=p.Name, dist=d, isNPC=false})
                end
            end
        end
    end

    local playerChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then playerChars[p.Character] = true end
    end
    local myChar = getChar()

    for _, model in ipairs(workspace:GetDescendants()) do
        if model:IsA("Model") and model ~= myChar and not playerChars[model] then
            local r = model:FindFirstChild("HumanoidRootPart")
            local h = model:FindFirstChildOfClass("Humanoid")
            if r and h and h.Health > 0 and not seen[r] then
                local d = (myRoot.Position - r.Position).Magnitude
                if d <= maxDist then
                    seen[r] = true
                    table.insert(list, {root=r, hum=h, name=model.Name, dist=d, isNPC=true})
                end
            end
        end
    end

    table.sort(list, function(a, b) return a.dist < b.dist end)
    return list
end

local function nearestTarget(maxDist)
    return getAllTargets(maxDist)[1]
end

