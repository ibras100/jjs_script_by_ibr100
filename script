local function camShake(intensity, duration)
    task.spawn(function()
        local t = 0
        while t < duration do
            local dt = task.wait(); t += dt; local dec=1-(t/duration)
            Cam.CFrame = Cam.CFrame * CFrame.Angles(
                math.rad((math.random()-0.5)*2*intensity*dec),
                math.rad((math.random()-0.5)*2*intensity*dec),
                math.rad((math.random()-0.5)*0.4*intensity*dec))
        end
    end)
end

-- ══════════════════════════════════════════════════════════════
--  BLACK FLASH ENGINE
-- ══════════════════════════════════════════════════════════════
local function doSingleBlackFlash(target)
    local mr = getRoot()
    if not mr or not target or not target.root then return false end

    if S.BFAutoTP then
        local d = (mr.Position - target.root.Position).Magnitude
        if d > S.BFTPOffset + 2 then
            local behind = (target.root.CFrame * CFrame.new(0, 0, S.BFTPOffset)).Position
            dashTo(behind, S.BFDashSpeed, 2)
        end
    end

    mr = getRoot()
    if mr and target.root then
        mr.CFrame = CFrame.lookAt(mr.Position, target.root.Position)
    end

    pressKey(S.BFSkeyCode)
    task.wait(S.BFTiming1)
    pressKey(S.BFSkeyCode)
    task.wait(S.BFTiming2)

    mr = getRoot()
    if mr then bfVFX(mr.CFrame); ringVFX(target.root.Position); camShake(2, 0.1) end

    BF_STATS.hits += 1; BF_STATS.cur += 1
    if BF_STATS.cur > BF_STATS.maxCombo then BF_STATS.maxCombo = BF_STATS.cur end
    return true
end

local function stopBFChain()
    S.BFActive = false
    if S.BFThread then task.cancel(S.BFThread); S.BFThread = nil end
    BF_STATS.cur = 0
    notify("BF Chain OFF",
        "Total hits: "..BF_STATS.hits.." | Max combo: "..BF_STATS.maxCombo.."x", 4)
end

local function startBFChain()
    if S.BFThread then task.cancel(S.BFThread); S.BFThread = nil end
    S.BFActive=true; BF_STATS.hits=0; BF_STATS.cur=0; BF_STATS.maxCombo=0
    notify("BF Chain ON",
        "Skill: "..tostring(S.BFSkeyCode).." | "..S.BFChainNum
        .."x | Timing "..math.floor(S.BFTiming1*1000).."ms", 3)

    S.BFThread = task.spawn(function()
        while S.BFActive do
            local target = S.LockTarget or nearestTarget(400)
            if not target then
                task.wait(0.5)
            elseif target.hum.Health <= 0 then
                BF_STATS.cur=0; task.wait(0.3)
            else
                if S.BFAutoTP then
                    local behind=(target.root.CFrame*CFrame.new(0,0,S.BFTPOffset)).Position
                    dashTo(behind, S.BFDashSpeed, 2)
                end
                local hits = 0
                for i = 1, S.BFChainNum do
                    if not S.BFActive then break end
                    if target.hum.Health <= 0 then BF_STATS.cur=0; break end
                    doSingleBlackFlash(target); hits += 1
                end
                if hits >= 2 then
                    notify("COMBO x"..hits, "BF Chain! Total: "..BF_STATS.hits, 2)
                end
                local mr2=getRoot()
                if mr2 then dashTo((mr2.CFrame*CFrame.new(0,0,5)).Position, 150, 1) end
                task.wait(S.BFCooldown)
            end
        end
    end)
end

