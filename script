local function bfVFX(origin)
    task.spawn(function()
        for i = 1, 4 do
            local bolt      = Instance.new("Part")
            bolt.Anchored   = true
            bolt.CanCollide = false
            bolt.CastShadow = false
            bolt.Size       = Vector3.new(0.15, math.random(3, 9), 0.15)
            bolt.Material   = Enum.Material.Neon
            bolt.Color      = Color3.fromRGB(180, 0, 255)
            bolt.CFrame     = origin
                * CFrame.Angles(math.random() * math.pi * 2, math.random() * math.pi * 2, 0)
                * CFrame.new(math.random(-3, 3), 0, math.random(-3, 3))
            bolt.Parent     = workspace
            local tw = TweenService:Create(
                bolt,
                TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                {Transparency = 1, Size = Vector3.new(0.04, bolt.Size.Y * 1.6, 0.04)}
            )
            tw:Play()
            tw.Completed:Wait()
            bolt:Destroy()
        end
    end)
end

local function ringVFX(pos)
    task.spawn(function()
        local r         = Instance.new("Part")
        r.Anchored      = true
        r.CanCollide    = false
        r.CastShadow    = false
        r.Shape         = Enum.PartType.Cylinder
        r.Size          = Vector3.new(0.1, 0.8, 0.8)
        r.CFrame        = CFrame.new(pos) * CFrame.Angles(0, 0, math.pi / 2)
        r.Material      = Enum.Material.Neon
        r.Color         = Color3.fromRGB(200, 0, 255)
        r.Transparency  = 0.2
        r.Parent        = workspace
        local tw = TweenService:Create(
            r,
            TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {Size = Vector3.new(0.04, 10, 10), Transparency = 1}
        )
        tw:Play()
        tw.Completed:Wait()
        r:Destroy()
    end)
end

local function camShake(i, d)
    task.spawn(function()
        local t = 0
        while t < d do
            local dt = task.wait()
            t = t + dt
            local dec = 1 - (t / d)
            Cam.CFrame = Cam.CFrame * CFrame.Angles(
                math.rad((math.random() - 0.5) * 2 * i * dec),
                math.rad((math.random() - 0.5) * 2 * i * dec),
                math.rad((math.random() - 0.5) * 0.4 * i * dec)
            )
        end
    end)
end

-- ══════════════════════════════════════════════════════════════
--  MOTEUR BLACK FLASH CHAIN
--  Méthode: VirtualInputManager + timing précis
-- ══════════════════════════════════════════════════════════════
local function doSingleBlackFlash(enemy)
    local mr = getRoot()
    if not mr then return false end

    -- TP si nécessaire
    if S.BFAutoTP and enemy then
        local er = enemy.Character and enemy.Character:FindFirstChild("HumanoidRootPart")
        if er then
            local d = (mr.Position - er.Position).Magnitude
            if d > S.BFTPOffset + 2 then
                mr.CFrame = er.CFrame * CFrame.new(0, 0, S.BFTPOffset)
                task.wait(0.04)
            end
        end
    end

    -- Black Flash : presse touche skill 1 fois
    pressKey(S.BFSkeyCode)
    -- Attend le "golden frame" (flash blanc dans l'anim)
    task.wait(S.BFTiming1)
    -- Presse à nouveau pour déclencher le Black Flash
    pressKey(S.BFSkeyCode)
    -- Attend le momentum
    task.wait(S.BFTiming2)

    -- VFX
    if mr then
        bfVFX(mr.CFrame)
        local er2 = enemy and enemy.Character and enemy.Character:FindFirstChild("HumanoidRootPart")
        if er2 then ringVFX(er2.Position) end
        camShake(2, 0.1)
    end

    BF_STATS.hits = BF_STATS.hits + 1
    BF_STATS.cur  = BF_STATS.cur  + 1
    if BF_STATS.cur > BF_STATS.maxCombo then
        BF_STATS.maxCombo = BF_STATS.cur
    end

    return true
end

local function stopBFChain()
    S.BFActive = false
    if S.BFThread then
        task.cancel(S.BFThread)
        S.BFThread = nil
    end
    BF_STATS.cur = 0
    notify(
        "BF Chain OFF",
        "Total hits : " .. BF_STATS.hits .. " | Max combo : " .. BF_STATS.maxCombo .. "x",
        4
    )
end

local function startBFChain()
    if S.BFThread then
        task.cancel(S.BFThread)
        S.BFThread = nil
    end
    S.BFActive    = true
    BF_STATS.hits = 0
    BF_STATS.cur  = 0
    BF_STATS.maxCombo = 0

    notify(
        "BF Chain ON",
        "Skill : " .. tostring(S.BFSkeyCode) ..
        " | " .. S.BFChainNum .. "x BF | Timing " ..
        math.floor(S.BFTiming1 * 1000) .. "ms",
        3
    )

    S.BFThread = task.spawn(function()
        while S.BFActive do
            -- Sélection de la cible
            local enemy = S.LockTarget
            if enemy == nil or enemy.Character == nil then
                enemy = nearestEnemy(300)
            end

            if enemy == nil or enemy.Character == nil then
                task.wait(0.5)
            else
                local hum = enemy.Character:FindFirstChildOfClass("Humanoid")
                if hum == nil or hum.Health <= 0 then
                    BF_STATS.cur = 0
                    task.wait(0.3)
                else
                    -- Phase 1 : Infinity TP
                    if S.BFAutoTP then
                        tpBehindEnemy(enemy, S.BFTPOffset)
                        task.wait(0.04)
                    end

                    -- Phase 2 : Rafale de Black Flash
                    local hits = 0
                    for i = 1, S.BFChainNum do
                        if not S.BFActive then break end

                        -- Vérifier si l'ennemi est toujours vivant
                        local h2 = enemy.Character and
                                   enemy.Character:FindFirstChildOfClass("Humanoid")
                        if h2 == nil or h2.Health <= 0 then
                            BF_STATS.cur = 0
                            break
                        end

                        doSingleBlackFlash(enemy)
                        hits = hits + 1
                    end

                    -- Notif combo
                    if hits >= 2 then
                        notify(
                            "COMBO x" .. hits,
                            "BF Chain ! Total : " .. BF_STATS.hits,
                            2
                        )
                    end

                    -- Step back
                    local mr2 = getRoot()
                    if mr2 then
                        mr2.CFrame = mr2.CFrame * CFrame.new(0, 0, 5)
                    end

                    task.wait(S.BFCooldown)
                end
            end
        end
    end)
end

-- ══════════════════════════════════════════════════════════════
--  AUTO FARM M1 (spam clic gauche en étant collé à l'ennemi)
-- ══════════════════════════════════════════════════════════════
local function startAutoFarm()
    task.spawn(function()
        while S.AutoFarm do
            local enemy, dist = nearestEnemy(300)
            if enemy and enemy.Character then
                local er = enemy.Character:FindFirstChild("HumanoidRootPart")
                local mr = getRoot()
                if er and mr then
                    -- Colle au range de hit
                    if dist > S.FarmRange then
                        mr.CFrame = er.CFrame * CFrame.new(0, 0, S.FarmRange - 0.5)
                    end
                    -- Regarde l'ennemi
                    mr.CFrame = CFrame.lookAt(mr.Position, er.Position)
                    -- M1
                    pressM1()
                end
            end
            task.wait(S.FarmDelay)
        end
    end)
end

-- ══════════════════════════════════════════════════════════════
--  AUTO BLOCK (maintenir F enfoncé quand ennemi proche)
-- ══════════════════════════════════════════════════════════════
local function startAutoBlock()
    task.spawn(function()
        local blocking = false
        while S.AutoBlock do
            local enemy, dist = nearestEnemy(20)
            if dist < 18 and not blocking then
                VirtualInputMgr:SendKeyEvent(true, KEYS.BLOCK, false, game)
                blocking = true
            elseif dist >= 18 and blocking then
                VirtualInputMgr:SendKeyEvent(false, KEYS.BLOCK, false, game)
                blocking = false
            end
            task.wait(0.05)
        end
        -- Release block
        VirtualInputMgr:SendKeyEvent(false, KEYS.BLOCK, false, game)
    end)
end

