--  KEY SYSTEM  (custom — runs before UI loads)
--  Fetches the valid key from pastebin, compares with input.
--  Saves to file so the user only enters it once.
-- ══════════════════════════════════════════════════════════════
local KEY_FILE = "JJS_Hub_Key.txt"
local KEY_URL  = "https://pastebin.com/raw/NwuUCDeq"

local function fetchValidKey()
    local ok, result = pcall(function() return game:HttpGet(KEY_URL) end)
    return ok and result:gsub("%s+", "") or nil
end

local function checkKey(input)
    local valid = fetchValidKey()
    if not valid then return false end
    return input:gsub("%s+", "") == valid
end

