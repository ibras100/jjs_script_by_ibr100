-- ══════════════════════════════════════════════════════════════
--  ESP
-- ══════════════════════════════════════════════════════════════
local ESPData={}

local function clearESP()
    for _,objs in pairs(ESPData) do
        for _,o in ipairs(objs) do
            pcall(function() if o and o.Parent then o:Destroy() end end)
        end
    end
    ESPData={}
end

local function makeESPForTarget(target)
    local key=tostring(target.root)
    if ESPData[key] then return end
    local objs={}
    local model=target.root:FindFirstAncestorOfClass("Model") or target.root.Parent

    local hl=Instance.new("Highlight")
    hl.FillColor=S.ESPFill; hl.OutlineColor=S.ESPOutline
    hl.FillTransparency=0.45; hl.OutlineTransparency=0
    hl.Adornee=model; hl.Parent=model
    table.insert(objs,hl)

    local bb=Instance.new("BillboardGui")
    bb.Size=UDim2.new(0,160,0,58); bb.StudsOffset=Vector3.new(0,4.5,0)
    bb.AlwaysOnTop=true; bb.Adornee=target.root; bb.Parent=target.root

    local bg=Instance.new("Frame",bb)
    bg.Size=UDim2.fromScale(1,1); bg.BackgroundColor3=Color3.fromRGB(8,8,14)
    bg.BackgroundTransparency=0.18
    local bgC=Instance.new("UICorner",bg); bgC.CornerRadius=UDim.new(0,8)
    local bgS=Instance.new("UIStroke",bg); bgS.Color=S.ESPFill

    local nameL=Instance.new("TextLabel",bg)
    nameL.Size=UDim2.new(1,0,0.38,0); nameL.BackgroundTransparency=1
    nameL.TextColor3=Color3.new(1,1,1); nameL.TextScaled=true
    nameL.Font=Enum.Font.GothamBold
    nameL.Text=(target.isNPC and "🤖 " or "⚔ ")..target.name

    local hpBg=Instance.new("Frame",bg)
    hpBg.Size=UDim2.new(0.9,0,0.13,0); hpBg.Position=UDim2.new(0.05,0,0.44,0)
    hpBg.BackgroundColor3=Color3.fromRGB(60,10,10)
    local hpBgC=Instance.new("UICorner",hpBg); hpBgC.CornerRadius=UDim.new(1,0)

    local hpFill=Instance.new("Frame",hpBg)
    local r0=math.clamp(target.hum.Health/math.max(target.hum.MaxHealth,1),0,1)
    hpFill.Size=UDim2.fromScale(r0,1); hpFill.BackgroundColor3=Color3.fromRGB(50,220,80)
    local hpFC=Instance.new("UICorner",hpFill); hpFC.CornerRadius=UDim.new(1,0)

    local infoL=Instance.new("TextLabel",bg)
    infoL.Size=UDim2.new(1,0,0.3,0); infoL.Position=UDim2.fromScale(0,0.68)
    infoL.BackgroundTransparency=1; infoL.TextColor3=Color3.fromRGB(200,200,200)
    infoL.TextScaled=true; infoL.Font=Enum.Font.Gotham; infoL.Text="❤ -- / --  📍 --"

    ESPData[key]=objs; table.insert(objs,bb)

    task.spawn(function()
        while S.ESP and target.root and target.root.Parent and ESPData[key] do
            local myR=getRoot()
            local ratio=math.clamp(target.hum.Health/math.max(target.hum.MaxHealth,1),0,1)
            hpFill.Size=UDim2.fromScale(ratio,1)
            hpFill.BackgroundColor3=ratio>0.6 and Color3.fromRGB(50,220,80)
                or ratio>0.3 and Color3.fromRGB(230,170,20)
                or Color3.fromRGB(220,40,40)
            local d=myR and math.floor((myR.Position-target.root.Position).Magnitude) or 0
            infoL.Text=string.format("❤ %d/%d  📍 %d",
                math.floor(target.hum.Health), math.floor(target.hum.MaxHealth), d)
            hl.FillColor=S.ESPFill; hl.OutlineColor=S.ESPOutline
            task.wait(0.15)
        end
    end)
end

local function refreshESP()
    for _,t in ipairs(getAllTargets(S.ESPDist)) do makeESPForTarget(t) end
end

