local function getChar()
    return LP.Character
end

local function getRoot()
    local c = getChar()
    if c then return c:FindFirstChild("HumanoidRootPart") end
    return nil
end

local function getHum()
    local c = getChar()
    if c then return c:FindFirstChildOfClass("Humanoid") end
    return nil
end

-- Ennemi le plus proche
local function nearestEnemy(maxDist)
    maxDist = maxDist or math.huge
    local root = getRoot()
    if not root then return nil, math.huge end
    local best     = nil
    local bestDist = maxDist
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if r and h and h.Health > 0 then
                local d = (root.Position - r.Position).Magnitude
                if d < bestDist then
                    bestDist = d
                    best     = p
                end
            end
        end
    end
    return best, bestDist
end

-- Tous les ennemis triés par distance
local function allEnemies(maxDist)
    maxDist = maxDist or math.huge
    local root = getRoot()
    if not root then return {} end
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if r and h and h.Health > 0 then
                local d = (root.Position - r.Position).Magnitude
                if d <= maxDist then
                    table.insert(list, {player = p, dist = d})
                end
            end
        end
    end
    table.sort(list, function(a, b) return a.dist < b.dist end)
    return list
end

-- ══════════════════════════════════════════════════════════════
--  TÉLÉPORTATION DIRECTE (CFrame — marche toujours)
-- ══════════════════════════════════════════════════════════════

-- Tp derrière un ennemi
local function tpBehindEnemy(enemy, offset)
    offset = offset or 4
    if not enemy or not enemy.Character then return false end
    local er = enemy.Character:FindFirstChild("HumanoidRootPart")
    local mr = getRoot()
    if er and mr then
        -- On se place derrière lui selon sa direction
        mr.CFrame = er.CFrame * CFrame.new(0, 0, offset)
        return true
    end
    return false
end

-- Tp devant un ennemi (face à lui)
local function tpFaceEnemy(enemy, offset)
    offset = offset or 4
    if not enemy or not enemy.Character then return false end
    local er = enemy.Character:FindFirstChild("HumanoidRootPart")
    local mr = getRoot()
    if er and mr then
        mr.CFrame = er.CFrame * CFrame.new(0, 0, -offset)
        -- On regarde vers l'ennemi
        mr.CFrame = CFrame.lookAt(mr.Position, er.Position)
        return true
    end
    return false
end

-- Tp à une position précise
local function tpTo(position, yOffset)
    yOffset = yOffset or 5
    local mr = getRoot()
    if mr then
        mr.CFrame = CFrame.new(position + Vector3.new(0, yOffset, 0))
        return true
    end
    return false
end

