local AuraSphere = nil

local function updateAura()
    local root = getRoot()
    if not root then return end
    if S.Aura then
        if AuraSphere == nil or AuraSphere.Parent == nil then
            AuraSphere = Instance.new("SelectionSphere")
            AuraSphere.SurfaceTransparency = 0.5
            AuraSphere.SurfaceColor3       = S.AuraColor
            AuraSphere.Color3              = S.AuraColor
            AuraSphere.Adornee             = root
            AuraSphere.Parent              = root
        end
    else
        if AuraSphere then
            AuraSphere:Destroy()
            AuraSphere = nil
        end
    end
end

